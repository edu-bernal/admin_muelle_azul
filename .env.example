# Base de datos PostgreSQL (usa el docker-compose incluido para desarrollo local)
DATABASE_URL="postgresql://muelle:muelle@localhost:5432/muelle_azul?schema=public"

# Secreto para firmar los JWT de sesión (genera uno con: openssl rand -base64 32)
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# URL pública de la app (para enlaces en correos)
APP_URL="http://localhost:3000"

# Credenciales del Super Admin inicial (se crean con el seed)
SEED_ADMIN_EMAIL="admin@muelleazul.pe"
SEED_ADMIN_PASSWORD="Admin1234!"
